{
    "name": "locky42/leopard-admin",
    "description": "A library for managing the administration panel of a web application.",
    "type": "library",
    "version": "1.0.1",
    "authors": [
        {
            "name": "Максим Зінченко",
            "email": "zinchenko.m.42@gmail.com"
        }
    ],
    "license": "MIT",
    "require": {
        "locky42/leopard-user": "1.0.0",
        "almasaeed2010/adminlte": "^3.2",
        "locky42/leopard-events": "^1.0",
        "locky42/leopard-doctrine": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.3"
    },
    "autoload": {
        "psr-4": {
            "Leopard\\Admin\\": "src/"
        },
        "files": ["bootstrap.php"]
    },
    "autoload-dev": {
        "psr-4": {
            "Leopard\\Admin\\Tests\\": "tests/"
        }
    }
}
